# Database (Neon Serverless)
# Find these in your Neon UI -> Connection Details
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-withered-queen-a7eercnf-pooler.ap-southeast-2.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=your_neon_password_here

# Security
# Generate a strong 256-bit Hex string for this
APP_JWT_SECRET=your_secure_jwt_secret_here

# Cache Config (Optional, falls back to simple if not provided)
CACHE_TYPE=simple
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend
# Add this environment variable in your Vercel Dashboard
VITE_API_URL=https://your-production-backend-domain.com/api
